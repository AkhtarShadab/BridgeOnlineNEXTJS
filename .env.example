# Environment variables (copy to .env and fill in values)

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/bridgeonline?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# Socket.io
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"

# Optional: Redis for caching (can be added later)
# REDIS_URL="redis://localhost:6379"

# Feature flags (redeploy to apply)
FEATURE_VOICE_CHAT=true
NEXT_PUBLIC_FEATURE_VOICE_CHAT=true
FEATURE_AI_HINTS=false
NEXT_PUBLIC_FEATURE_NEW_UI=false
FEATURE_RECONNECT_GRACE=false
NEXT_PUBLIC_FEATURE_RECONNECT_GRACE=false
